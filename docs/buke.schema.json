{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Buke Pack Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Schema declaration."
    },
    "name": {
      "type": "string",
      "description": "App display name."
    },
    "id": {
      "type": "string",
      "description": "Bundle identifier (e.g. com.example.app)."
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Web app URL to wrap."
    },
    "locale": {
      "type": "string",
      "description": "Preferred language code for runtime rendering and UI labels."
    },
    "partition": {
      "type": "string",
      "description": "Webview session partition (e.g. persist:default)."
    },
    "zoom": {
      "type": "number",
      "description": "Zoom level (0.5-2.0 or 50-200; values >10 are divided by 100)."
    },
    "allowlist": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Additional allowed hostnames or URL patterns for cross-domain navigation. Built-in defaults already include localhost, 127.0.0.1, and chrome-extension origins."
    },
    "icon": {
      "type": "string",
      "description": "App icon path or URL. When omitted, fetches favicon from Google's favicon service."
    },
    "outDir": {
      "type": "string",
      "description": "Output directory for pack command."
    },
    "env": {
      "type": "string",
      "enum": ["dev", "canary", "stable"],
      "description": "Electrobun build environment."
    },
    "useLocalFile": {
      "type": "string",
      "description": "Path to a local HTML file to package instead of a URL."
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "width": { "type": "number" },
        "height": { "type": "number" },
        "minWidth": { "type": "number" },
        "minHeight": { "type": "number" },
        "hideTitleBar": { "type": "boolean" },
        "fullscreen": { "type": "boolean" },
        "maximized": { "type": "boolean" },
        "alwaysOnTop": { "type": "boolean", "description": "Keep window above all others." },
        "title": { "type": "string", "description": "Override window title." }
      },
      "description": "Window size, title bar, and behavior options."
    },
    "tray": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "icon": { "type": "string" },
        "hideOnClose": { "type": "boolean" }
      },
      "description": "System tray settings."
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "userAgent": { "type": "string" },
        "proxyUrl": { "type": "string" }
      },
      "description": "Webview network overrides."
    },
    "navigation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "forceInternalNavigation": {
          "type": "boolean",
          "description": "Redirect all navigations into main webview."
        },
        "internalUrlRegex": {
          "type": "string",
          "description": "Regex pattern for URLs to keep in-app."
        },
        "disabledWebShortcuts": {
          "type": "boolean",
          "description": "Block Ctrl/Cmd keyboard shortcuts on web page."
        },
        "newWindow": { "type": "boolean", "description": "Allow popup windows for auth flows." }
      },
      "description": "Navigation control settings."
    },
    "instance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "multiInstance": { "type": "boolean", "description": "Allow multiple app instances." },
        "activationShortcut": {
          "type": "string",
          "description": "Global shortcut to toggle window visibility (e.g. CmdOrControl+Shift+P)."
        }
      },
      "description": "App instance management."
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "darkMode": { "type": "boolean", "description": "Force dark color scheme in webview." },
        "startToTray": {
          "type": "boolean",
          "description": "Start hidden (requires tray.enabled)."
        },
        "debug": {
          "type": "boolean",
          "description": "Enable verbose logging and auto-open DevTools."
        },
        "incognito": {
          "type": "boolean",
          "description": "Use non-persisting session (no cookies saved)."
        },
        "enableDragDrop": {
          "type": "boolean",
          "description": "Enable file drag and drop support."
        },
        "pastePlainText": { "type": "boolean", "description": "Force paste as plain text." },
        "ignoreCertificateErrors": {
          "type": "boolean",
          "description": "Ignore TLS certificate errors."
        },
        "wasm": { "type": "boolean", "description": "Enable WebAssembly CORS isolation." },
        "camera": {
          "type": "boolean",
          "description": "Request camera permission (macOS entitlement)."
        },
        "microphone": {
          "type": "boolean",
          "description": "Request microphone permission (macOS entitlement)."
        },
        "multiWindow": { "type": "boolean", "description": "Enable multi-window support via menu." }
      },
      "description": "Runtime behavior settings."
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "appVersion": { "type": "string", "description": "Application version string." },
        "install": {
          "type": "boolean",
          "description": "Install app after build (macOS: cp to /Applications)."
        },
        "iterativeBuild": {
          "type": "boolean",
          "description": "Skip DMG/installer, produce app bundle only."
        }
      },
      "description": "Build and distribution settings."
    },
    "inject": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "css": {
          "type": "array",
          "items": { "type": "string" }
        },
        "js": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "description": "Custom style/script injection assets for the webview."
    },
    "macosSafeArea": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "top": { "type": "number" },
        "left": { "type": "number" },
        "right": { "type": "number" },
        "bottom": { "type": "number" }
      },
      "description": "macOS safe-area padding."
    },
    "about": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "label": { "type": "string" },
              "url": { "type": "string" },
              "separator": { "type": "boolean" }
            }
          }
        }
      },
      "description": "About menu configuration."
    },
    "i18n": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "menu": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "description": "Runtime UI localization overrides."
    }
  }
}
