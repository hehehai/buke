{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Buke Pack Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Schema declaration."
    },
    "name": {
      "type": "string",
      "description": "App display name."
    },
    "id": {
      "type": "string",
      "description": "Bundle identifier (e.g. com.example.app)."
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Web app URL to wrap."
    },
    "locale": {
      "type": "string",
      "description": "Preferred language code for runtime rendering and UI labels."
    },
    "partition": {
      "type": "string",
      "description": "Webview session partition (e.g. persist:default)."
    },
    "allowlist": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Additional allowed hostnames or URL patterns for cross-domain navigation. Built-in defaults already include localhost, 127.0.0.1, and chrome-extension origins."
    },
    "icon": {
      "type": "string",
      "description": "App icon path or URL."
    },
    "outDir": {
      "type": "string",
      "description": "Output directory for pack command."
    },
    "env": {
      "type": "string",
      "enum": ["dev", "canary", "stable"],
      "description": "Electrobun build environment."
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "width": { "type": "number" },
        "height": { "type": "number" },
        "minWidth": { "type": "number" },
        "minHeight": { "type": "number" },
        "hideTitleBar": { "type": "boolean" },
        "fullscreen": { "type": "boolean" },
        "maximized": { "type": "boolean" }
      },
      "description": "Window size and title bar options."
    },
    "tray": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "icon": { "type": "string" },
        "hideOnClose": { "type": "boolean" }
      },
      "description": "System tray settings."
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "userAgent": { "type": "string" },
        "proxyUrl": { "type": "string" }
      },
      "description": "Webview network overrides."
    },
    "inject": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "css": {
          "type": "array",
          "items": { "type": "string" }
        },
        "js": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "description": "Custom style/script injection assets for the webview."
    },
    "macosSafeArea": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "top": { "type": "number" },
        "left": { "type": "number" },
        "right": { "type": "number" },
        "bottom": { "type": "number" }
      },
      "description": "macOS safe-area padding."
    },
    "about": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "label": { "type": "string" },
              "url": { "type": "string" },
              "separator": { "type": "boolean" }
            }
          }
        }
      },
      "description": "About menu configuration."
    },
    "i18n": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "menu": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "description": "Runtime UI localization overrides."
    }
  }
}
