{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["bun"],
    "paths": {
      "electrobun/bun": ["types/electrobun.d.ts"],
      "electrobun": ["types/electrobun.d.ts"]
    },
    "lib": ["ES2022", "DOM"]
  },
  "include": ["packages/**/*.ts", "types/**/*.d.ts"],
  "exclude": ["**/node_modules/**", "**/dist/**", "**/build/**", "**/.tmp/**"]
}
